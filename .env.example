# ============================================================
# Cactus Light & Sound ERP - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# ------------------------------------------------------------
# CURRENT STACK (MongoDB - active)
# ------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=cactus_erp
NEXT_PUBLIC_BASE_URL=https://your-app.preview.emergentagent.com
CORS_ORIGINS=*

# Cookie session signing secret (any long random string)
SESSION_SECRET=replace-with-a-long-random-string

# App display name (optional)
NEXT_PUBLIC_APP_NAME=Cactus Light & Sound ERP

# ------------------------------------------------------------
# SUPABASE (planned migration - fill in when ready)
# ------------------------------------------------------------
# Where to obtain these:
#   1. https://supabase.com/dashboard -> Create / open project
#   2. Settings -> API
#      - Project URL              -> NEXT_PUBLIC_SUPABASE_URL
#      - Project API keys -> anon -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#      - Project API keys -> service_role (SECRET) -> SUPABASE_SERVICE_ROLE_KEY
#
# IMPORTANT:
#   - NEXT_PUBLIC_* keys are bundled into the browser. Only put PUBLIC keys there.
#   - SUPABASE_SERVICE_ROLE_KEY bypasses RLS. NEVER expose it to the browser.
#     Use it only in server-side code (API routes, Server Actions).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket names (created in Supabase Dashboard -> Storage)
NEXT_PUBLIC_SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
NEXT_PUBLIC_SUPABASE_COMPANY_LOGOS_BUCKET=company-logos

# ------------------------------------------------------------
# NODE
# ------------------------------------------------------------
NODE_ENV=development
